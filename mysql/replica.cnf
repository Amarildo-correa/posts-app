# mysql/replica.cnf
# ─────────────────────────────────────────────────────────────
# Configuração do MySQL Replica — recebe leitura
# Montado em /etc/mysql/conf.d/ dentro do container mysql_replica
# ─────────────────────────────────────────────────────────────

[mysqld]

# ── Identidade na topologia de replicação ─────────────────────
# server-id diferente do Master — obrigatório
# MySQL rejeita replicação com server-id duplicado
# convenção: Replica usa 2, 3, 4... se houver múltiplas Replicas
server-id = 2

# ── Relay log — buffer local dos eventos recebidos ────────────
# o IO Thread salva aqui os eventos baixados do Master
# o SQL Thread lê daqui e aplica no banco da Replica
# dois processos separados — desacoplamento que permite replicação assíncrona
# a Replica pode processar eventos no próprio ritmo sem bloquear o Master
relay-log = mysql-relay-bin

# ── Proteção contra escrita direta ────────────────────────────
# bloqueia qualquer INSERT, UPDATE, DELETE direto na Replica
# dados só podem entrar via SQL Thread (replicação)
# se o Node.js tentar escrever na Replica por engano → erro imediato
# é a proteção que o Instagram usa para garantir que dados vêm só do Master
read_only = ON

# ── Escopo da replicação ──────────────────────────────────────
# replica APENAS o banco posts_app_db — espelha o escopo do Master
replicate_do_db = posts_app_db