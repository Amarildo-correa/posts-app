# ─────────────────────────────────────────────────────────────
# CONFIGURAÇÃO REPLICA - O NÓ DE LEITURA (READER)
# ─────────────────────────────────────────────────────────────
# Didática: A Réplica serve para escalar o Comentaaê. Se o feed
# tiver 1 milhão de acessos, as buscas vão para cá, deixando o
# Master livre para processar apenas as novas postagens.
# ─────────────────────────────────────────────────────────────

[mysqld]
# Identidade única: Deve ser diferente do Master. Usamos 2.
server-id = 2

# ── Relay Log (O Buffer de Recepção) ──────────────────────────
# Enquanto o Master tem o 'Binary Log' (saída), a Réplica tem o
# 'Relay Log' (entrada). Ela baixa as mudanças do Master, guarda
# aqui temporariamente e depois as aplica no banco.
relay-log = mysql-relay-bin

# ── Blindagem de Integridade (Read Only) ──────────────────────
# Didática: Ativamos o modo 'Somente Leitura'. Isso impede que, por
# erro de código, a aplicação tente salvar um post aqui.
# Dados só entram aqui via replicação vinda do Master.
read_only = ON

# ── SEGURANÇA DE TRANSPORTE (SSL) ──────────────────────────────
# A Réplica também exige SSL para que o Node.js e o Master falem
# com ela de forma segura. Utilizamos os mesmos certificados.
# ─────────────────────────────────────────────────────────────

require_secure_transport = ON
ssl-ca = /etc/mysql/certs/ca.pem
ssl-cert = /etc/mysql/certs/server-cert.pem
ssl-key = /etc/mysql/certs/server-key.pem