# ─────────────────────────────────────────────────────────────
# CONFIGURAÇÃO MASTER - O NÓ DE ESCRITA (WRITER)
# ─────────────────────────────────────────────────────────────
# Didática: Em sistemas como o Instagram, o Master é o único lugar
# onde ocorrem INSERTs e UPDATEs. Ele precisa ser o mais rápido
# possível e garantir que nada seja perdido (Durabilidade).
# ─────────────────────────────────────────────────────────────

[mysqld]
# ── Identidade Única ──────────────────────────────────────────
# O MySQL exige que cada nó na rede tenha um ID numérico único.
# Por convenção de engenharia, o Master sempre assume o ID 1.
server-id = 1

# ── O Coração da Replicação: Binary Log ───────────────────────
# O Master não envia dados diretamente para a Réplica. Ele anota
# todas as mudanças em um "diário" chamado Binary Log.
# A Réplica "lê" esse diário e repete as ações localmente.
log_bin = mysql-bin

# ── Formato ROW (Segurança de Dados) ──────────────────────────
# Didática: Existem dois modos. O modo 'Statement' grava a query SQL.
# O modo 'ROW' (que usamos aqui) grava o resultado final do dado.
# Isso evita erros se a query usar funções como NOW() ou RAND(),
# garantindo que Master e Réplica tenham exatamente os mesmos bits.
binlog_format = ROW

# ── Expiração de Logs (Limpeza Automática) ────────────────────
# Binary logs ocupam muito espaço. Configuramos para durar 7 dias.
# Tempo suficiente para recuperar uma réplica que caiu, sem lotar o disco.
binlog_expire_logs_seconds = 604800

# ── BLINDAGEM SSL/TLS (ARQUITETURA ZERO TRUST) ────────────────
# Didática: Em uma rede Zero Trust, não confiamos nem na rede interna.
# Forçamos o banco a só aceitar conversas se houver criptografia.
# ─────────────────────────────────────────────────────────────

# O 'Segurança da Porta': Rejeita qualquer tentativa de login que 
# não utilize uma conexão encriptada. Se o hacker entrar na rede
# interna do Docker, ele não conseguirá "escutar" a senha do banco.
require_secure_transport = ON

# A 'Certidão de Nascimento' (CA): Este arquivo é o selo de confiança.
# Todos os outros componentes usam este arquivo para verificar se o
# Master é realmente quem diz ser.
ssl-ca = /etc/mysql/certs/ca.pem

# O 'Passaporte' (Certificado): O documento que o Master apresenta
# durante o "handshake" inicial para provar sua identidade.
ssl-cert = /etc/mysql/certs/server-cert.pem

# A 'Chave do Cofre' (Private Key): Este é o segredo matemático.
# Ele nunca sai do container. É o que permite ao Master assinar as
# mensagens para garantir que elas não foram alteradas no caminho.
ssl-key = /etc/mysql/certs/server-key.pem