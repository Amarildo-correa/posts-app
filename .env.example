# .env.example
# Template das variáveis de ambiente do projeto
# Copie esse arquivo para .env e preencha com seus valores reais
# Esse arquivo SOBE pro GitHub — sem valores reais, só os nomes das variáveis

# ── Servidor ──────────────────────────────
PORT=3000
NODE_ENV=development

# ── MySQL ─────────────────────────────────
DB_HOST=mysql_posts_app
DB_PORT=3306
DB_NAME=posts_app_db
DB_USER=posts_user
DB_PASSWORD=sua_senha_aqui
DB_ROOT_PASSWORD=sua_senha_root_aqui

# ── Sessão ────────────────────────────────
SESSION_SECRET=sua_chave_secreta_aqui_minimo_32_caracteres